# Telegram Bot
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321
BOT_URL=https://t.me/YourBotUsername

# PostgreSQL
PG_DSN=postgresql://user:password@localhost:5432/bot_db

# Redis
REDIS_DSN=redis://localhost:6379/0
REDIS_RATE_DSN=redis://localhost:6379/1
REDIS_SESSION_DSN=redis://localhost:6379/2

# ClickHouse (RAG vector search)
CH_HOST=127.0.0.1
CH_PORT=8123
CH_USER=default
CH_PASS=
CH_DB=bot_db
CH_TABLE=rag_documents

# Ollama (embeddings + local AI)
OLLAMA_URL=http://localhost:11434
OLLAMA_EMB_MODEL=bge-m3
EMB_DIM=1024
LOCAL_AI_URL=http://127.0.0.1:8090/completion

# LLM Provider (VseGPT / any OpenAI-compatible)
VSEGPT_KEY=your_vsegpt_key
VSEGPT_MODEL_CHAT=qwen/qwq-32b
VSEGPT_MODEL_CODE=deepseek/deepseek-chat-0324-alt

# Google Gemma (optional free model)
GEMMA_API_KEY=your_gemma_key

# GitHub (for repo scanner feature)
GITHUB_TOKEN=your_github_token

# Telegra.ph (for article publishing)
TELEGRAPH_TOKEN=your_telegraph_token

# Payments - Platega
PLATEGA_MERCHANT_ID=your_merchant_id
PLATEGA_SECRET=your_secret
PLATEGA_CALLBACK=https://yourdomain.com/payments/platega

# Payments - CryptoBot
CRYPTOBOT_TOKEN=your_cryptobot_token

# Bot deploy sandbox
PREVIEW_TOKENS=token1,token2,token3,token4
SANDBOX_ROOT=/var/www/bot/sandbox
SANDBOX_BASE_URL=https://yourdomain.com/sandbox
BOTS_DIR=/opt/bot/preview_bots
LOGS_DIR=/opt/bot/preview_logs

# Links shown in bot UI
TERMS_URL=https://telegra.ph/your-terms-page
HELP_URL=https://telegra.ph/your-help-page

# Logging
LOG_FILE=/opt/bot/logs/bot.log
